// GemVault — One Piece TCG community platform
// Schema is split into: Users, Cards, Collection, Selling, Buying, Messaging, Moderation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
}

enum CardCondition {
  MINT
  NEAR_MINT
  EXCELLENT
  GOOD
  PLAYED
  POOR
}

enum CardLanguage {
  EN
  JP
  ZH
  KR
}

enum SellMode {
  COLLECTION
  OPEN_TO_OFFERS
  LISTED_FOR_SALE
}

enum ListingStatus {
  ACTIVE
  RESERVED
  SOLD
  CANCELLED
  EXPIRED
}

enum BuyRequestStatus {
  ACTIVE
  FULFILLED
  CANCELLED
  EXPIRED
}

enum ShippingPreference {
  SHIPPING_ONLY
  MEETUP_ONLY
  BOTH
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum ReportTargetType {
  USER
  LISTING
  BUY_REQUEST
  MESSAGE
  CARD
}

enum SaleStatus {
  PENDING_BUYER_CONFIRM
  CONFIRMED
  DISPUTED
  CANCELLED
}

enum Game {
  ONE_PIECE
  POKEMON
}

enum OripaStatus {
  DRAFT
  ACTIVE
  SOLD_OUT
  ARCHIVED
}

enum OripaTier {
  S
  A
  B
  C
  D
}

// ============================================================
// USERS / PROFILES
// Linked to Supabase auth.users via userId
// ============================================================

model Profile {
  id                 String             @id @default(cuid())
  userId             String             @unique // Supabase auth.users.id
  email              String             @unique
  username           String             @unique
  displayName        String?
  avatarUrl          String?
  bio                String?

  // Location (city/state level only — never exact address)
  city               String?
  state              String?
  country            String?            @default("Malaysia")

  // Roles & trust
  role               UserRole           @default(USER)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  rating             Float?
  totalSales         Int                @default(0)
  totalPurchases     Int                @default(0)

  // Future KYC integration hooks
  kycProvider        String?
  kycReference       String?
  kycVerifiedAt      DateTime?

  // Status
  isBanned           Boolean            @default(false)
  banReason          String?

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  userCards             UserCard[]
  saleListings          SaleListing[]
  sellPreferences       SellPreference[]
  buyRequests           BuyRequest[]
  conversationsAsBuyer  Conversation[]   @relation("ConversationBuyer")
  conversationsAsSeller Conversation[]   @relation("ConversationSeller")
  messages              Message[]
  reportsMade           Report[]         @relation("Reporter")
  reportsReceived       Report[]         @relation("ReportedUser")
  salesAsSeller         Sale[]           @relation("SaleSeller")
  salesAsBuyer          Sale[]           @relation("SaleBuyer")
  ratingsGiven          SaleRating[]     @relation("RatingRater")
  ratingsReceived       SaleRating[]     @relation("RatingRated")
  oripaSeriesCreated    OripaSeries[]    @relation("OripaCreator")
  oripaLastOneWins      OripaSeries[]    @relation("OripaLastOneWinner")
  oripaDraws            OripaSlot[]      @relation("OripaDrawer")
  oripaCredits          OripaCredit[]    @relation("OripaCreditUser")
  oripaCreditsGranted   OripaCredit[]    @relation("OripaCreditGranter")

  @@index([username])
  @@index([city, state])
  @@index([role])
}

// ============================================================
// CARD MASTER DATA
// ============================================================

model CardSet {
  id          String    @id @default(cuid())
  code        String    @unique // OP01, ST01 (One Piece) / BASE1, SV1 (Pokémon)
  name        String
  game        Game      @default(ONE_PIECE)
  description String?
  releaseDate DateTime?
  imageUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  cards Card[]

  @@index([code])
  @@index([game])
}

model Card {
  id        String  @id @default(cuid())
  cardCode  String  @unique // OP01-001 (One Piece) / BASE1-4 (Pokémon)
  name      String
  setId     String
  set       CardSet @relation(fields: [setId], references: [id])
  game      Game    @default(ONE_PIECE)

  rarity    String  // OP: C/UC/R/SR/SEC/L — PKM: Common/Rare Holo/...
  cardType  String  // OP: LEADER/CHARACTER/EVENT/STAGE — PKM: POKEMON/TRAINER/ENERGY
  colors    String[] // OP: card colors — PKM: energy types
  cost      Int?
  power     Int?
  counter   Int?
  life      Int?
  attribute String?  // Slash, Strike, Ranged, Special, Wisdom

  effectText  String?
  triggerText String?
  imageUrl    String?

  // Variant flags
  isAlternateArt Boolean        @default(false)
  isParallel     Boolean        @default(false)
  isPromo        Boolean        @default(false)
  languages      CardLanguage[]

  // Future pricing integration hooks
  marketPriceMyr       Float?
  marketPriceUpdatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userCards   UserCard[]
  buyRequests BuyRequest[]
  sales       Sale[]
  oripaPrizes OripaPrize[]

  @@index([setId])
  @@index([name])
  @@index([cardType])
  @@index([rarity])
  @@index([game])
}

// ============================================================
// COLLECTION (user-owned cards)
// A UserCard exists independently of any sale activity.
// sellMode determines whether it's also exposed as a listing or open to offers.
// ============================================================

model UserCard {
  id             String        @id @default(cuid())
  ownerId        String
  owner          Profile       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  cardId         String
  card           Card          @relation(fields: [cardId], references: [id])

  quantity       Int           @default(1)
  condition      CardCondition @default(NEAR_MINT)
  language       CardLanguage  @default(EN)
  isAlternateArt Boolean       @default(false)
  note           String?
  photoUrl       String?

  sellMode       SellMode      @default(COLLECTION)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  saleListing    SaleListing?
  sellPreference SellPreference?

  @@index([ownerId])
  @@index([cardId])
  @@index([sellMode])
}

// ============================================================
// SELLING — Active fixed-price listings
// ============================================================

model SaleListing {
  id             String             @id @default(cuid())
  sellerId       String
  seller         Profile            @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  userCardId     String             @unique
  userCard       UserCard           @relation(fields: [userCardId], references: [id], onDelete: Cascade)

  priceMyr       Float
  shippingPref   ShippingPreference @default(BOTH)
  shippingFeeMyr Float?
  description    String?

  status         ListingStatus      @default(ACTIVE)
  expiresAt      DateTime?
  soldAt         DateTime?
  views          Int                @default(0)

  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  conversations  Conversation[]
  sales          Sale[]

  @@index([sellerId])
  @@index([status])
  @@index([priceMyr])
}

// ============================================================
// SELLING — Passive "open to offers"
// ============================================================

model SellPreference {
  id              String             @id @default(cuid())
  ownerId         String
  owner           Profile            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  userCardId      String             @unique
  userCard        UserCard           @relation(fields: [userCardId], references: [id], onDelete: Cascade)

  minimumPriceMyr Float
  shippingPref    ShippingPreference @default(BOTH)
  note            String?
  isActive        Boolean            @default(true)

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([ownerId])
  @@index([isActive])
  @@index([minimumPriceMyr])
}

// ============================================================
// BUYING — Buy requests / wanted posts
// ============================================================

model BuyRequest {
  id             String             @id @default(cuid())
  buyerId        String
  buyer          Profile            @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  cardId         String
  card           Card               @relation(fields: [cardId], references: [id])

  minCondition   CardCondition      @default(GOOD)
  language       CardLanguage?
  quantity       Int                @default(1)
  maxPriceMyr    Float
  shippingPref   ShippingPreference @default(BOTH)
  preferredCity  String?
  preferredState String?
  note           String?

  status         BuyRequestStatus   @default(ACTIVE)
  expiresAt      DateTime?

  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([buyerId])
  @@index([cardId])
  @@index([status])
  @@index([maxPriceMyr])
}

// ============================================================
// MESSAGING — simple thread + messages
// ============================================================

model Conversation {
  id            String       @id @default(cuid())
  buyerId       String
  buyer         Profile      @relation("ConversationBuyer", fields: [buyerId], references: [id])
  sellerId      String
  seller        Profile      @relation("ConversationSeller", fields: [sellerId], references: [id])

  saleListingId String?
  saleListing   SaleListing? @relation(fields: [saleListingId], references: [id])

  lastMessageAt DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  messages      Message[]

  @@unique([buyerId, sellerId, saleListingId])
  @@index([buyerId])
  @@index([sellerId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         Profile      @relation(fields: [senderId], references: [id])
  body           String
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([senderId])
}

// ============================================================
// MODERATION
// ============================================================

model Report {
  id             String           @id @default(cuid())
  reporterId     String
  reporter       Profile          @relation("Reporter", fields: [reporterId], references: [id])
  reportedUserId String?
  reportedUser   Profile?         @relation("ReportedUser", fields: [reportedUserId], references: [id])

  targetType     ReportTargetType
  targetId       String?
  reason         String
  detail         String?
  status         ReportStatus     @default(PENDING)
  resolutionNote String?

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([status])
  @@index([reportedUserId])
  @@index([targetType, targetId])
}

// ============================================================
// SALES — completed transactions
// Recorded with mutual confirmation so we have trustworthy
// price + volume data per card for the GemVault market signal.
// ============================================================

model Sale {
  id               String       @id @default(cuid())

  sellerId         String
  seller           Profile      @relation("SaleSeller", fields: [sellerId], references: [id])
  buyerId          String
  buyer            Profile      @relation("SaleBuyer", fields: [buyerId], references: [id])

  // What was sold (snapshot — UserCard may be deleted after confirm)
  cardId           String
  card             Card         @relation(fields: [cardId], references: [id])
  condition        CardCondition
  language         CardLanguage
  isAlternateArt   Boolean      @default(false)

  finalPriceMyr    Float

  // Optional context — null for direct/open-to-offers sales
  saleListingId    String?
  saleListing      SaleListing? @relation(fields: [saleListingId], references: [id], onDelete: SetNull)

  // Lifecycle
  status           SaleStatus   @default(PENDING_BUYER_CONFIRM)
  sellerMarkedAt   DateTime     @default(now())
  buyerConfirmedAt DateTime?
  disputedAt       DateTime?
  cancelledAt      DateTime?

  sellerNote       String?
  buyerDisputeNote String?

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  ratings          SaleRating[]

  @@index([sellerId])
  @@index([buyerId])
  @@index([cardId, status])
  @@index([status])
}

model SaleRating {
  id        String   @id @default(cuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  raterId   String
  rater     Profile  @relation("RatingRater", fields: [raterId], references: [id])
  ratedId   String
  rated     Profile  @relation("RatingRated", fields: [ratedId], references: [id])

  stars     Int      // 1-5
  review    String?
  createdAt DateTime @default(now())

  @@unique([saleId, raterId])
  @@index([ratedId])
  @@index([saleId])
}

// ============================================================
// ORIPA — Japanese-style original packs (gacha draws)
// Admin builds a prize pool, activation shuffles prizes into
// numbered slots, users spend admin-granted credits to draw.
// Payment happens off-platform; credits are the entitlement.
// ============================================================

model OripaSeries {
  id              String      @id @default(cuid())
  title           String
  description     String?
  game            Game?       // null = mixed / other
  coverImageUrl   String?
  pricePerDrawMyr Float       // display price; payment collected off-platform

  status          OripaStatus @default(DRAFT)
  totalSlots      Int         @default(0) // set at activation
  activatedAt     DateTime?
  soldOutAt       DateTime?

  createdById     String
  createdBy       Profile     @relation("OripaCreator", fields: [createdById], references: [id])

  // ラストワン賞 — awarded to whoever draws the final pack
  lastOneWinnerId String?
  lastOneWinner   Profile?    @relation("OripaLastOneWinner", fields: [lastOneWinnerId], references: [id])

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  prizes          OripaPrize[]
  slots           OripaSlot[]
  credits         OripaCredit[]

  @@index([status])
  @@index([createdById])
}

model OripaPrize {
  id           String      @id @default(cuid())
  seriesId     String
  series       OripaSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  tier         OripaTier
  name         String      // e.g. "Shanks OP01-120 Alt Art (PSA 10)"
  cardId       String?     // optional link to catalog card
  card         Card?       @relation(fields: [cardId], references: [id])
  imageUrl     String?     // custom photo; falls back to card.imageUrl
  quantity     Int         @default(1) // how many of this prize in the pool
  estValueMyr  Float?
  isLastOne    Boolean     @default(false) // last-one prize — not slot-assigned

  createdAt    DateTime    @default(now())

  slots        OripaSlot[]

  @@index([seriesId])
  @@index([tier])
}

model OripaSlot {
  id          String      @id @default(cuid())
  seriesId    String
  series      OripaSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  slotNumber  Int         // 1..totalSlots — the pack number users pick
  prizeId     String
  prize       OripaPrize  @relation(fields: [prizeId], references: [id], onDelete: Cascade)

  drawnById   String?
  drawnBy     Profile?    @relation("OripaDrawer", fields: [drawnById], references: [id])
  drawnAt     DateTime?
  fulfilled   Boolean     @default(false) // admin marks after shipping/handover
  fulfilledAt DateTime?

  @@unique([seriesId, slotNumber])
  @@index([seriesId, drawnById])
  @@index([drawnById])
}

model OripaCredit {
  id          String      @id @default(cuid())
  seriesId    String
  series      OripaSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  userId      String
  user        Profile     @relation("OripaCreditUser", fields: [userId], references: [id])
  credits     Int         @default(0) // remaining draws for this series
  grantedById String
  grantedBy   Profile     @relation("OripaCreditGranter", fields: [grantedById], references: [id])

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([seriesId, userId])
  @@index([userId])
}
