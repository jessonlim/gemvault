# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Database (Postgres via Supabase) ---
# Use the "Connection pooling" string for DATABASE_URL (port 6543)
# Use the "Direct connection" string for DIRECT_URL (port 5432)
DATABASE_URL="postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:5432/postgres"

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
